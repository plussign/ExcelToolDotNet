{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug ExcelTool 增量提取文字",
      "type": "coreclr",
      "request": "launch",
      "program": "${workspaceFolder}/bin/Debug/net9.0/ExcelTool.exe",
      "args": ["-extra_text"],
      "cwd": "..\\Master\\Config",
      "preLaunchTask": "build",
      "stopAtEntry": false,
      "console": "integratedTerminal"
    },
    {
      "name": "Debug ExcelTool 全新提取文字",
      "type": "coreclr",
      "request": "launch",
      "program": "${workspaceFolder}/bin/Debug/net9.0/ExcelTool.exe",
      "args": ["-extra_text", "-clean_extra_text"],
      "cwd": "..\\Master\\Config",
      "preLaunchTask": "build",
      "stopAtEntry": false,
      "console": "integratedTerminal"
    },
    {
      "name": "Debug ExcelTool 转表",
      "type": "coreclr",
      "request": "launch",
      "program": "${workspaceFolder}/bin/Debug/net9.0/ExcelTool.exe",
      "args": [],
      "cwd": "..\\Master\\Config",
      "preLaunchTask": "build",
      "stopAtEntry": false,
      "console": "integratedTerminal"
    },
    {
      "name": "Run ExcelTool (No Debug)",
      "type": "node-terminal",
      "request": "launch",
      "command": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"Set-Location '${workspaceFolder}\\..\\Master\\Config'; & '${workspaceFolder}\\bin\\Release\\net9.0\\win-x64\\publish\\ExcelTool.exe'\"",
      "preLaunchTask": "build"
    },
    {
      "name": "Launch ExcelTool macOS (Debug)",
      "type": "coreclr",
      "request": "launch",
      "program": "${workspaceFolder}/bin/Debug/net9.0/ExcelTool",
      "args": [],
      "cwd": "${workspaceFolder}/../Master/Config",
      "preLaunchTask": "build",
      "stopAtEntry": false,
      "console": "integratedTerminal"
    },
    {
      "name": "Launch ExcelTool Release (.NET 9)",
      "type": "coreclr",
      "request": "launch",
      "program": "${workspaceFolder}/bin/Release/net9.0/ExcelTool.exe",
      "args": [],
      "cwd": "..\\Master\\Config",
      "preLaunchTask": "build-release",
      "stopAtEntry": false,
      "console": "integratedTerminal"
    }
  ]
}
